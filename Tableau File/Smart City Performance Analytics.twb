      <aliases enabled='yes' />
      <column caption='S2 : Normalized Energy' datatype='real' name='[Calculation_0802932878090240]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='((1000 - [Energy Consumption]) / (1000 - 100)) * 100' />
      </column>
      <column caption='S2 : Green Score' datatype='real' name='[Calculation_0802932878180353]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Air Quality Index] * 0.25) + &#13;&#10;([Calculation_0802932878090240] * 0.25) + &#13;&#10;([Waste Management Score] * 0.25) + &#13;&#10;([Public Transport Usage] * 0.25)' />
      </column>
      <column caption='S2 : City Rank' datatype='integer' name='[Calculation_0802932878512130]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(SUM([Calculation_0802932878180353]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='S2 : Top/Bottom Filter' datatype='boolean' name='[Calculation_0802932878811139]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_0802932878512130] &lt;= 50 OR [Calculation_0802932878512130] &gt; 4950'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='S2 : Top/Bottom Color Split' datatype='string' name='[Calculation_0802932880056324]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0802932878512130] &lt;= 50 THEN &quot;Top 50&quot;&#13;&#10;ELSEIF [Calculation_0802932878512130] &gt; 4950 THEN &quot;Bottom 50&quot;&#13;&#10;ELSE &quot;Middle&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='S3 : Economic Potential' datatype='real' name='[Calculation_0802932888367109]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(([Employment Rate] / 100) * 50) + (([Population] / 10000000) * 50)' />
      </column>
      <column caption='S3 : Infrastructure Gap' datatype='real' name='[Calculation_0802932888449030]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(100 - [Smart Infrastructure Score] + (100 - [Internet Speed (Mbps)])) / 2' />
      </column>
      <column caption='S4 : Dynamic Livability Score' datatype='real' name='[Calculation_0802932896649223]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Healthcare Index] * [Parameters].[Parameter 2]) +&#13;&#10;([Safety Index] * [Parameters].[Parameter 3]) +&#13;&#10;([Education Index] * [Parameters].[Parameter 4]) +&#13;&#10;([Air Quality Index] * [Parameters].[Parameter 5]) +&#13;&#10;([Employment Rate] * [Parameters].[Parameter 6])' />
      </column>
      <column caption='S4 : Healthcare 20th' datatype='real' name='[Calculation_0802932897370120]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : PERCENTILE([Healthcare Index], 0.2) }' />
      </column>
      <column caption='S4 : Safety 20th' datatype='real' name='[Calculation_0802932897513481]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : PERCENTILE([Safety Index], 0.2) }' />
      </column>
      <column caption='S4 : Education 20th' datatype='real' name='[Calculation_0802932898091018]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : PERCENTILE([Education Index], 0.2) }' />
      </column>
      <column caption='S4 : Air Quality 20th' datatype='real' name='[Calculation_0802932898209803]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : PERCENTILE([Air Quality Index], 0.2) }' />
      </column>
      <column caption='S4 : Employment Rate' datatype='real' name='[Calculation_0802932898324492]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='PERCENTILE([Employment Rate], 0.2)' />
      </column>
      <column caption='S4 : Employment 20th' datatype='real' name='[Calculation_0802932902952974]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : PERCENTILE([Employment Rate], 0.2) }' />
      </column>
      <column caption='S4 : Dimensions Below Threshold' datatype='integer' name='[Calculation_0802932903276559]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(IF [Healthcare Index] &lt; [Calculation_0802932897370120] THEN 1 ELSE 0 END) +&#13;&#10;(IF [Safety Index] &lt; [Calculation_0802932897513481] THEN 1 ELSE 0 END) +&#13;&#10;(IF [Education Index] &lt; [Calculation_0802932898091018] THEN 1 ELSE 0 END) +&#13;&#10;(IF [Air Quality Index] &lt; [Calculation_0802932898209803] THEN 1 ELSE 0 END) +&#13;&#10;(IF [Employment Rate] &lt; [Calculation_0802932902952974] THEN 1 ELSE 0 END)' />
      </column>
      <column caption='S4 : Critical City Status' datatype='string' name='[Calculation_0802932903579664]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0802932903276559] &gt;= 3 THEN &quot;CRITICAL&quot; ELSE &quot;NORMAL&quot; END' />
      </column>
      <column caption='S4 : Population Tier' datatype='string' name='[Calculation_0802932905291793]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Population] &lt; 100000 THEN &quot;Small City (Under 100K)&quot;&#13;&#10;ELSEIF [Population] &lt;= 1000000 THEN &quot;Mid-Size City (100K - 1M)&quot;&#13;&#10;ELSE &quot;Metropolitan City (Over 1M)&quot;&#13;&#10;END' />
      </column>
      <column caption='S4 : Boolean Filter' datatype='boolean' name='[Calculation_0802932909047826]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[City Name] = [Parameters].[Parameter 1]' />
      </column>
      <column caption='S4 : Selected City Value' datatype='real' name='[Calculation_0802932926529561]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [City Name] = [Select a City] THEN [Measure Values] END' />
      </column>
      <column caption='S1 : Selected City Population' datatype='integer' name='[Calculation_1429929168809984]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [City Name] = [Parameters].[Parameter 1] THEN [Population] END) }' />
      </column>
      <column caption='S1 : Peer City Filter' datatype='boolean' name='[Calculation_1429929169047553]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Population] &gt;= ([Calculation_1429929168809984] * 0.8) &#13;&#10;AND [Population] &lt;= ([Calculation_1429929168809984] * 1.2)' />
      </column>
      <column caption='S1 : Chosen City Category' datatype='string' name='[Calculation_1429929169719298]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [City Name] = [Parameters].[Parameter 1] THEN &quot;Selected City&quot; ELSE &quot;Peer City&quot; END' />
      </column>
      <column caption='S1 : Peer City Rank' datatype='integer' name='[Calculation_1429929170849795]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Smart Infrastructure Score]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='S1 : Top 10 peer cities' datatype='boolean' name='[Calculation_1429929172037636]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1429929170849795] &lt;= 10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
