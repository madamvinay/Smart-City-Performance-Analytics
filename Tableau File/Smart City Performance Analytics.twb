    <worksheet name='S4 : Tier Analysis'>
      <table>
        <view>
          <datasources>
            <datasource caption='smart_city_dataset' name='federated.02vxp4e1llj0661h8b8kg1coxkni' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='S4 : Weight Healthcare' datatype='real' name='[Parameter 2]' param-domain-type='range' role='measure' type='quantitative' value='0.2'>
              <calculation class='tableau' formula='0.2' />
              <range max='1.0' min='0.0' />
            </column>
            <column caption='S4 : Weight Safety' datatype='real' name='[Parameter 3]' param-domain-type='range' role='measure' type='quantitative' value='0.2'>
              <calculation class='tableau' formula='0.2' />
              <range max='1.0' min='0.0' />
            </column>
            <column caption='S4 : Weight Education' datatype='real' name='[Parameter 4]' param-domain-type='range' role='measure' type='quantitative' value='0.2'>
              <calculation class='tableau' formula='0.2' />
              <range max='1.0' min='0.0' />
            </column>
            <column caption='S4 : Weight AQI' datatype='real' name='[Parameter 5]' param-domain-type='range' role='measure' type='quantitative' value='0.2'>
              <calculation class='tableau' formula='0.2' />
              <range max='1.0' min='0.0' />
            </column>
            <column caption='S4 : Weight Employment' datatype='real' name='[Parameter 6]' param-domain-type='range' role='measure' type='quantitative' value='0.2'>
              <calculation class='tableau' formula='0.2' />
              <range max='1.0' min='0.0' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.02vxp4e1llj0661h8b8kg1coxkni'>
            <column datatype='real' name='[Air Quality Index]' role='measure' type='quantitative' />
            <column caption='S4 : Dynamic Livability Score' datatype='real' name='[Calculation_0802932896649223]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Healthcare Index] * [Parameters].[Parameter 2]) +&#13;&#10;([Safety Index] * [Parameters].[Parameter 3]) +&#13;&#10;([Education Index] * [Parameters].[Parameter 4]) +&#13;&#10;([Air Quality Index] * [Parameters].[Parameter 5]) +&#13;&#10;([Employment Rate] * [Parameters].[Parameter 6])' />
            </column>
            <column caption='S4 : Healthcare 20th' datatype='real' name='[Calculation_0802932897370120]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : PERCENTILE([Healthcare Index], 0.2) }' />
            </column>
            <column caption='S4 : Safety 20th' datatype='real' name='[Calculation_0802932897513481]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : PERCENTILE([Safety Index], 0.2) }' />
            </column>
            <column caption='S4 : Education 20th' datatype='real' name='[Calculation_0802932898091018]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : PERCENTILE([Education Index], 0.2) }' />
            </column>
            <column caption='S4 : Air Quality 20th' datatype='real' name='[Calculation_0802932898209803]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : PERCENTILE([Air Quality Index], 0.2) }' />
            </column>
            <column caption='S4 : Employment 20th' datatype='real' name='[Calculation_0802932902952974]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : PERCENTILE([Employment Rate], 0.2) }' />
            </column>
            <column caption='S4 : Dimensions Below Threshold' datatype='integer' name='[Calculation_0802932903276559]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(IF [Healthcare Index] &lt; [Calculation_0802932897370120] THEN 1 ELSE 0 END) +&#13;&#10;(IF [Safety Index] &lt; [Calculation_0802932897513481] THEN 1 ELSE 0 END) +&#13;&#10;(IF [Education Index] &lt; [Calculation_0802932898091018] THEN 1 ELSE 0 END) +&#13;&#10;(IF [Air Quality Index] &lt; [Calculation_0802932898209803] THEN 1 ELSE 0 END) +&#13;&#10;(IF [Employment Rate] &lt; [Calculation_0802932902952974] THEN 1 ELSE 0 END)' />
            </column>
            <column caption='S4 : Critical City Status' datatype='string' name='[Calculation_0802932903579664]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0802932903276559] &gt;= 3 THEN &quot;CRITICAL&quot; ELSE &quot;NORMAL&quot; END' />
            </column>
            <column caption='S4 : Population Tier' datatype='string' name='[Calculation_0802932905291793]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Population] &lt; 100000 THEN &quot;Small City (Under 100K)&quot;&#13;&#10;ELSEIF [Population] &lt;= 1000000 THEN &quot;Mid-Size City (100K - 1M)&quot;&#13;&#10;ELSE &quot;Metropolitan City (Over 1M)&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[City Name]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column datatype='real' name='[Education Index]' role='measure' type='quantitative' />
            <column datatype='real' name='[Employment Rate]' role='measure' type='quantitative' />
            <column datatype='real' name='[Healthcare Index]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Population]' role='measure' type='quantitative' />
            <column datatype='real' name='[Safety Index]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0802932903579664]' derivation='None' name='[none:Calculation_0802932903579664:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0802932905291793]' derivation='None' name='[none:Calculation_0802932905291793:nk]' pivot='key' type='nominal' />
            <column-instance column='[City Name]' derivation='None' name='[none:City Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0802932896649223]' derivation='Sum' name='[sum:Calculation_0802932896649223:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Shape' />
