            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.02vxp4e1llj0661h8b8kg1coxkni'>
            <column caption='S1 : Selected City Population' datatype='integer' name='[Calculation_1429929168809984]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX(IF [City Name] = [Parameters].[Parameter 1] THEN [Population] END) }' />
            </column>
            <column caption='S1 : Peer City Filter' datatype='boolean' name='[Calculation_1429929169047553]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Population] &gt;= ([Calculation_1429929168809984] * 0.8) &#13;&#10;AND [Population] &lt;= ([Calculation_1429929168809984] * 1.2)' />
            </column>
            <column caption='S1 : Chosen City Category' datatype='string' name='[Calculation_1429929169719298]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [City Name] = [Parameters].[Parameter 1] THEN &quot;Selected City&quot; ELSE &quot;Peer City&quot; END' />
            </column>
            <column caption='S1 : Peer City Rank' datatype='integer' name='[Calculation_1429929170849795]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='RANK(SUM([Smart Infrastructure Score]), &apos;desc&apos;)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='S1 : Top 10 peer cities' datatype='boolean' name='[Calculation_1429929172037636]' role='measure' type='nominal'>
              <calculation class='tableau' formula='[Calculation_1429929170849795] &lt;= 10'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[City Name]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column datatype='real' name='[Energy Consumption]' role='measure' type='quantitative' />
