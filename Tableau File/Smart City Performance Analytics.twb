              <zone h='37890' id='12' type-v2='text' w='38770' x='44824' y='61068'>
                <formatted-text>
                  <run bold='true' fontcolor='#000000' fontname='Methodology: Sustainability Index'>Methodology: Sustainability Index</run>
                  <run>Æ&#10;</run>
                  <run fontcolor='#000000' fontname='Google Sans Text,sans-serif'>To ensure unbiased city benchmarking, all metrics were standardized using </run>
                  <run bold='true' fontcolor='#000000' fontname='Google Sans Text,sans-serif'>Min-Max Normalization</run>
                  <run fontcolor='#000000' fontname='Google Sans Text,sans-serif'> (0–100 scale).</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontname='Google Sans Text,sans-serif'>Energy Consumption:</run>
                  <run fontcolor='#000000' fontname='Google Sans Text,sans-serif'> Inverted ($100 - Normalized Value$) to align lower consumption with higher performance.</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontname='Google Sans Text,sans-serif'>Weighting:</run>
                  <run fontcolor='#000000' fontname='Google Sans Text,sans-serif'> A </run>
                  <run bold='true' fontcolor='#000000' fontname='Google Sans Text,sans-serif'>25% equal-split</run>
                  <run fontcolor='#000000' fontname='Google Sans Text,sans-serif'> was applied across </run>
                  <run fontcolor='#000000' fontname='Google Sans Text,sans-serif' italic='true'>Air Quality, Energy, Waste Management, and Public Transport</run>
                  <run fontcolor='#000000' fontname='Google Sans Text,sans-serif'> to ensure a balanced, holistic Green Score.</run>
                </formatted-text>
                <zone-style>
                  <format attr='border-color' value='#000000' />
                  <format attr='border-style' value='none' />
                  <format attr='border-width' value='0' />
                  <format attr='margin' value='4' />
                </zone-style>
              </zone>
            </zone>
            <zone fixed-size='160' h='97916' id='6' is-fixed='true' param='vert' type-v2='layout-flow' w='15625' x='83594' y='1042'>
