            </encodings>
            <reference-line axis-column='[federated.02vxp4e1llj0661h8b8kg1coxkni].[sum:Calculation_0802932896649223:qk]' boxplot-mark-exclusion='false' boxplot-whisker-type='standard' enable-instant-analytics='true' formula='average' id='refline0' label-type='automatic' probability='95' scope='per-cell' symmetric='false' value-column='[federated.02vxp4e1llj0661h8b8kg1coxkni].[sum:Calculation_0802932896649223:qk]' z-order='1' />
